{
  "name": "original-software-hub-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "mkdir -p ./assets/css && tailwindcss -c ./tailwind.config.cjs -i ./tailwind.input.css -o ./assets/css/tailwind.css --minify",
    "build": "npm run build:css && node ./scripts/build.mjs",
    "dev": "npm run build && node ./scripts/dev-server.mjs"
  },
  "devDependencies": {
    "html-minifier-terser": "^7.2.0",
    "tailwindcss": "^3.4.17",
    "terser": "^5.39.2"
  }
}